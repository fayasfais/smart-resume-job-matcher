# Groq API Key - get yours for free at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Optional: override the default Groq model
GROQ_MODEL=llama-3.3-70b-versatile

# Optional: directory where ChromaDB persists its vector store on disk.
# Leave unset / remove this line to run with an in-memory (ephemeral) store.
CHROMA_PERSIST_DIR=./chroma_db
